{
  "name": "bilitune",
  "version": "1.0.0",
  "private": true,
  "description": "BiliTune - Spotify/Apple Music style Bilibili music client for Windows & Android",
  "scripts": {
    "dev:desktop": "pnpm --filter @bilitune/desktop dev",
    "build:desktop": "pnpm --filter @bilitune/desktop build",
    "dev:mobile": "pnpm --filter @bilitune/mobile start",
    "build:shared": "pnpm --filter @bilitune/shared build",
    "build:api": "pnpm --filter @bilitune/api build",
    "build:store": "pnpm --filter @bilitune/store build",
    "build:packages": "pnpm build:shared && pnpm build:api && pnpm build:store",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "node-forge": "^1.4.0"
  }
}
